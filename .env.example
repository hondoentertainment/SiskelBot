# Backend: ollama | vllm | openai (default: ollama)
BACKEND=ollama

# Production (Vercel): Set BACKEND=openai, OPENAI_API_KEY, and API_KEY. Ollama/vLLM localhost won't work.

# Ollama (when BACKEND=ollama) - default for local dev
OLLAMA_URL=http://localhost:11434

# vLLM (when BACKEND=vllm)
VLLM_URL=http://localhost:8000

# OpenAI (when BACKEND=openai) - required for OpenAI
# OPENAI_API_KEY=sk-...

# Server
PORT=3000

# Optional: protect /v1/chat/completions with API key
# Production (Vercel): Strongly recommended. Set API_KEY in Vercel env vars.
# API_KEY=your-secret-key

# Rate limiting (optional)
# RATE_LIMIT_WINDOW_MS=60000
# RATE_LIMIT_MAX=60
# RATE_LIMIT_MAX_PER_USER=100   # Phase 21: Per-user limit when auth configured (default: RATE_LIMIT_MAX)

# Phase 21: Per-workspace token quotas (optional)
# QUOTA_TOKENS_PER_WORKSPACE=100000   # Tokens per workspace per period. When unset, no quota enforcement.
# QUOTA_WORKSPACE_PERIOD_DAYS=30      # Quota period in days (default: 30)
# QUOTA_ADMIN_USER_IDS=user1,user2    # Comma-separated userIds that bypass quota

# Phase 25: Admin Dashboard
# ADMIN_API_KEY=...                  # Protects /admin and /api/admin/*. Or use QUOTA_ADMIN_USER_IDS (OAuth/session).

# Phase 13: Observability & Cost Control - optional usage budget alert
# When total tokens in rolling window exceeds this, responses include X-Usage-Alert: 1
# USAGE_ALERT_TOKENS=1000000

# Phase 18: Conversation Analytics - cost estimation (OpenAI only; Ollama/vLLM = local)
# ANALYTICS_COST_PER_1K_INPUT=0.002   # $ per 1K input tokens (default: gpt-4o-mini approx)
# ANALYTICS_COST_PER_1K_OUTPUT=0.006  # $ per 1K output tokens

# Phase 14: User Authentication & Workspaces
# USER_API_KEYS=key1:user1,key2:user2   # User API keys (header: Authorization Bearer or x-user-api-key). When set, storage/workspaces require auth.
# Or use data/users.json: { "key1": "user1" } or { "users": [{ "apiKey": "k", "userId": "u" }] }
# When not set: anonymous user, single default workspace (backward compatible).

# Phase 19: OAuth & SSO
# GITHUB_CLIENT_ID=...            # GitHub OAuth App client ID
# GITHUB_CLIENT_SECRET=...        # GitHub OAuth App client secret
# GOOGLE_CLIENT_ID=...            # Google OAuth client ID
# GOOGLE_CLIENT_SECRET=...        # Google OAuth client secret
# SESSION_SECRET=...              # Required for OAuth session persistence. Use a long random string in production.
# BASE_URL=https://your-domain.com  # For production OAuth callbacks. Default: http://localhost:PORT in dev.

# Phase 15: Agentic Autonomy Mode
# ALLOW_RECIPE_STEP_EXECUTION=1   # Enable execute_step tool (build, deploy). Requires client "Allow recipe step execution" toggle.
# MAX_AGENT_ITERATIONS=5          # Max tool-call loop iterations (default: 5)

# Phase 24: Backup & Restore
# BACKUP_ADMIN_KEY=...            # Protects backup/restore API and GET /api/backup/cron. Pass via ?secret= for cron.
# BACKUP_MAX_RETAINED=7           # Max backups to keep (default: 7)

# Phase 16: Scheduled & Automated Recipes
# ENABLE_SCHEDULED_RECIPES=1      # Enable in-process cron scheduler (local). When set, node-cron runs recipes per schedule.
# CRON_SECRET=...                 # Optional; protects GET /api/cron for Vercel Cron. Pass via Authorization: Bearer <secret> or ?secret=.

# Phase 17: Plugins & Extensions
# ALLOW_WEBHOOK_ACTIONS=1         # Enable webhook action (POST to URL). Requires HTTPS, rate-limited 5/min per URL.
# PLUGINS_PATH=./plugins           # Optional; path to plugins dir containing config.json. Default: ./plugins.

# Phase 22: Event Webhooks & Notifications
# ALLOW_WEBHOOK_LOCALHOST=1       # Allow http://localhost and private IPs for webhook URLs (dev only).

# Phase 18: Conversation Analytics & Insights (optional cost estimation for OpenAI)
# ANALYTICS_COST_PER_1K_INPUT=0.002   # $ per 1K input tokens (default: gpt-4o-mini approx)
# ANALYTICS_COST_PER_1K_OUTPUT=0.006 # $ per 1K output tokens. Ollama/vLLM = local ($0).

# Toolchain Integration Hub (Phase 4) - optional. Tokens stay server-side; never exposed to client.
# GITHUB_TOKEN=ghp_...  # For /api/github/repos, /api/github/repo/:owner/:repo, /api/github/issues/:owner/:repo
# VERCEL_TOKEN=...      # For /api/vercel/deployments, /api/vercel/projects
